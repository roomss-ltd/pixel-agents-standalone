layout {
    default_tab_template {
        children
        pane size=2 borderless=true {
            plugin location="file:__HOME__/zellij-plugins/zjstatus.wasm" {

                // ── Catppuccin Mocha palette ───────────────────────────────
                color_base      "#1E1E2E"
                color_surface0  "#313244"
                color_surface1  "#45475A"
                color_overlay0  "#6C7086"
                color_overlay1  "#7F849C"
                color_text      "#CDD6F4"
                color_subtext   "#A6ADC8"
                color_blue      "#89B4FA"
                color_lavender  "#B4BEFE"
                color_sapphire  "#74C7EC"
                color_green     "#A6E3A1"
                color_yellow    "#F9E2AF"
                color_peach     "#FAB387"
                color_red       "#F38BA8"
                color_surface2  "#585B70"
                color_mauve     "#CBA6F7"

                // ── Layout ────────────────────────────────────────────────
                format_left   " {mode} {tabs}"
                format_center ""
                format_right  "{pipe_branch}#[fg=$subtext,bg=$base] ┃ #[fg=$subtext,bg=$base]{datetime}"
                format_space  "#[bg=$base]"

                format_hide_on_overlength "true"
                format_precedence         "lrc"

                // ── Border (heavy line for more visual weight) ─────────────
                border_enabled  "false"
                border_char     "━"
                border_format   "#[fg=$surface1,bg=$base]{char}"
                border_position "top"

                hide_frame_for_single_pane "false"

                // ── Modes (icon per mode for quick recognition) ────────────
                mode_normal        "#[fg=$base,bg=$blue] 󰆾 #[fg=$blue,bg=$base]"
                mode_insert        "#[fg=$base,bg=$green] 󰏫 #[fg=$green,bg=$base]"
                mode_locked        "#[fg=$base,bg=$red] 󰌾 #[fg=$red,bg=$base]"
                mode_pane          "#[fg=$base,bg=$mauve] 󰕮 #[fg=$mauve,bg=$base]"
                mode_tab           "#[fg=$base,bg=$yellow] 󰓩 #[fg=$yellow,bg=$base]"
                mode_scroll        "#[fg=$base,bg=$peach] 󱕖 #[fg=$peach,bg=$base]"
                mode_resize        "#[fg=$base,bg=$yellow] 󰩨 #[fg=$yellow,bg=$base]"
                mode_move          "#[fg=$base,bg=$mauve] 󰆾 #[fg=$mauve,bg=$base]"
                mode_search        "#[fg=$base,bg=$sapphire] 󰍉 #[fg=$sapphire,bg=$base]"
                mode_entersearch   "#[fg=$base,bg=$sapphire] 󰍉 #[fg=$sapphire,bg=$base]"
                mode_renametab     "#[fg=$base,bg=$yellow] 󰑕 #[fg=$yellow,bg=$base]"
                mode_renamepane    "#[fg=$base,bg=$yellow] 󰑕 #[fg=$yellow,bg=$base]"
                mode_tmux          "#[fg=$base,bg=$peach]  #[fg=$peach,bg=$base]"
                mode_default_to_mode "normal"

                // ── Tabs: square index badge + connected name block ─────────
                tab_normal              "#[fg=$base,bg=$surface2] {index} #[fg=$overlay1,bg=$surface0] {name} {floating_indicator}{sync_indicator}#[fg=$surface0,bg=$base]"
                tab_active              "#[fg=$base,bg=$peach,bold] {index} #[fg=$peach,bg=$surface1,bold] {name} {floating_indicator}{sync_indicator}#[fg=$surface1,bg=$base]"
                tab_normal_fullscreen   "#[fg=$base,bg=$surface2] {index} #[fg=$overlay1,bg=$surface0] {name} {fullscreen_indicator}#[fg=$surface0,bg=$base]"
                tab_active_fullscreen   "#[fg=$base,bg=$peach,bold] {index} #[fg=$peach,bg=$surface1,bold] {name} {fullscreen_indicator}#[fg=$surface1,bg=$base]"
                tab_normal_sync         "#[fg=$base,bg=$surface2] {index} #[fg=$overlay1,bg=$surface0] {name} {sync_indicator}#[fg=$surface0,bg=$base]"
                tab_active_sync         "#[fg=$base,bg=$green,bold] {index} #[fg=$green,bg=$surface1,bold] {name} {sync_indicator}#[fg=$surface1,bg=$base]"
                tab_rename              "#[fg=$base,bg=$yellow,bold] {index} #[fg=$yellow,bg=$surface1,bold] 󰑕 {name} #[fg=$surface1,bg=$base]"
                tab_separator           "#[fg=$base,bg=$base] "
                tab_fullscreen_indicator "󰊓 "
                tab_sync_indicator       " "
                tab_floating_indicator   "󰉯 "

                // ── Git branch via pipe (shell pushes on cwd change) ───────
                pipe_branch_format               "#[fg=$overlay1,bg=$base]  {output}"

                // ── Datetime ──────────────────────────────────────────────
                datetime          "{format}"
                datetime_format   "󰥔 %H:%M  ┃  󰃭 %d %b %Y "
                datetime_timezone "Europe/Chisinau"
            }
        }
    }
}
